# Copy this file to .env and fill in your values

# Shared Neon database (get connection string from team)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google Gemini — free tier, get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Optional: Anthropic Claude (preferred over Gemini if set)
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Voyage AI embeddings (preferred over Gemini if set)
# Get key at https://dash.voyageai.com/
VOYAGE_API_KEY=your_voyage_key_here
