# Copy this file to .env and fill in your values.

# ── Local dev auth bypass ─────────────────────────────────────────────────────
# Set AUTH_DISABLED=true to skip Azure AD token validation locally.
# Returns a hardcoded dev@local user (firm_id=1). NEVER set this in production.
AUTH_DISABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1 — Local (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://brokeruser:brokerpass@localhost:5432/brokerdb
# Option 2 — Neon (shared dev database, get connection string from neon.tech):
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require&channel_binding=require
# Option 3 — Azure Flexible Server (production):
# DATABASE_URL=postgresql://brokeruser:<password>@<server>.postgres.database.azure.com:5432/brokerdb?sslmode=require

# ── LLM / AI keys ─────────────────────────────────────────────────────────────
# Antire Azure AI Foundry is the primary provider — OpenAI-compatible endpoint
# fronting gpt-5.4 / gpt-5.4-mini / kimi / glm under one base URL and key.
# Other providers below are legacy fallbacks being phased out (Phase 1 of the
# LLM-stack consolidation; see CLAUDE.md).

# Antire Azure AI Foundry (primary)
AZURE_FOUNDRY_BASE_URL=https://antire-dev-resource.services.ai.azure.com/api/projects/antire-dev/openai/v1
AZURE_FOUNDRY_API_KEY=your_foundry_key_here
AZURE_FOUNDRY_MODEL=gpt-5.4-mini

# Google Vertex AI — primary provider for Gemini PDF extraction
# (prod-grade SLA, EU residency in europe-west4). Set up via:
#   gcloud projects create antire-decelerates-prod
#   gcloud services enable aiplatform.googleapis.com
#   gcloud iam service-accounts create vertex-ai-runtime
#   gcloud iam service-accounts keys create sa.json --iam-account=vertex-ai-runtime@...
# In Container Apps, GCP_VERTEX_AI_SA_JSON is set as a GitHub secret and
# api/main.py writes it to /tmp at startup. Locally, point
# GOOGLE_APPLICATION_CREDENTIALS at the downloaded JSON instead.
GCP_VERTEX_AI_PROJECT=antire-decelerates-prod
GCP_VERTEX_AI_LOCATION=europe-west4
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Google Gemini AI Studio — legacy free-tier API key, used as fallback when
# Vertex AI is not configured. Free tier at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=       # optional — rotated automatically on quota exhaustion
GEMINI_API_KEY_3=       # optional

# Anthropic Claude — legacy, used by agentic PDF discovery + as text fallback
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Voyage AI — legacy embeddings provider (falls back to Gemini if not set)
# Get key at https://dash.voyageai.com/
VOYAGE_API_KEY=your_voyage_key_here
