# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# Local (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://brokeruser:brokerpass@localhost:5432/brokerdb
# Azure Flexible Server (replace placeholders):
# DATABASE_URL=postgresql://brokeruser:<password>@<server>.postgres.database.azure.com:5432/brokerdb?sslmode=require

# ── LLM / AI keys ─────────────────────────────────────────────────────────────
# At least one of Gemini or Anthropic is required.

# Google Gemini — free tier at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=       # optional — rotated automatically on quota exhaustion
GEMINI_API_KEY_3=       # optional

# Anthropic Claude — preferred for text generation + agentic PDF discovery
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Voyage AI — higher-quality RAG embeddings (falls back to Gemini if not set)
# Get key at https://dash.voyageai.com/
VOYAGE_API_KEY=your_voyage_key_here
