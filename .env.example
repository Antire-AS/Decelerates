# Copy this file to .env and fill in your values.

# ── Local dev auth bypass ─────────────────────────────────────────────────────
# Set AUTH_DISABLED=true to skip Azure AD token validation locally.
# Returns a hardcoded dev@local user (firm_id=1). NEVER set this in production.
AUTH_DISABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1 — Local (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://brokeruser:brokerpass@localhost:5432/brokerdb
# Option 2 — Neon (shared dev database, get connection string from neon.tech):
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require&channel_binding=require
# Option 3 — Azure Flexible Server (production):
# DATABASE_URL=postgresql://brokeruser:<password>@<server>.postgres.database.azure.com:5432/brokerdb?sslmode=require

# ── LLM / AI keys ─────────────────────────────────────────────────────────────
# Two providers serve all prod LLM traffic after the Phase 4.5 consolidation:
#
#   - Antire Azure AI Foundry (gpt-5.4-mini): all chat, NL→SQL, embeddings
#   - Google Vertex AI (gemini-2.5-flash):    all PDF / multimodal extraction
#
# The remaining keys below (ANTHROPIC_API_KEY, GEMINI_API_KEY[_2/_3]) are kept
# only for the agentic IR PDF discovery in api/services/pdf_agents.py, which
# is a separate Phase 4 follow-up. The Voyage AI fallback was removed in
# Phase 4.5 — Foundry text-embedding-3-small replaces it entirely.

# Antire Azure AI Foundry — primary chat + embeddings
AZURE_FOUNDRY_BASE_URL=https://antire-dev-resource.services.ai.azure.com/api/projects/antire-dev/openai/v1
AZURE_FOUNDRY_API_KEY=your_foundry_key_here
AZURE_FOUNDRY_MODEL=gpt-5.4-mini

# Google Vertex AI — primary multimodal / PDF extraction (gemini-2.5-flash)
# europe-west4 for EU residency. Auth via GOOGLE_APPLICATION_CREDENTIALS
# locally; in Container Apps GCP_VERTEX_AI_SA_JSON is base64-encoded as a
# GitHub secret and api/main.py materialises it to /tmp at startup.
GCP_VERTEX_AI_PROJECT=antire-decelerates-prod
GCP_VERTEX_AI_LOCATION=europe-west4
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# ── Legacy keys retained only for the agentic IR PDF discovery flow ──────────
# These are no longer used by the chat / embedding / PDF-extraction paths.
# Will be removed when api/services/pdf_agents.py is migrated or deleted.

# Google Gemini AI Studio (used by pdf_agents Gemini agent loop)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=       # optional — multi-key rotation for the agent
GEMINI_API_KEY_3=       # optional

# Anthropic Claude (used by pdf_agents Claude agent loop)
ANTHROPIC_API_KEY=your_anthropic_key_here
