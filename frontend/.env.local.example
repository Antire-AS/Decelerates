# Next.js / NextAuth — copy to .env.local and fill in values
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Azure Entra ID (App Registration for the frontend)
# Leave blank to run without auth (backend must have AUTH_DISABLED=true)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# FastAPI backend URL (server-side only, skips the /api rewrite)
API_BASE_URL=http://localhost:8000
